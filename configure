#!/bin/sh
# wisp interactive configurator.
#
# Picks a config (configs/*.wisp), a font backend, and a font file, then writes
# config.mk — which the Makefile includes — and optionally builds + installs.
# Pure POSIX sh; no compile step to run it. Re-run any time; `make config` is
# an alias. CLI `make FONT_BACKEND=... FONT=...` always overrides config.mk.
set -eu
cd "$(dirname "$0")"

say()  { printf '%s\n' "$*"; }
# ask <prompt> <default> -> echoes the answer on stdout (prompt goes to stderr,
# so it stays visible when the call is captured by $(...)).
ask() {
    if [ -n "$2" ]; then printf '%s [%s]: ' "$1" "$2" >&2
    else                 printf '%s: ' "$1" >&2; fi
    read -r _ans || _ans=
    if [ -n "$_ans" ]; then printf '%s\n' "$_ans"; else printf '%s\n' "$2"; fi
}

say "wisp configurator"
say "================="
say ""

# ---- 1) config -----------------------------------------------------------
say "Configs available in configs/:"
i=0; defidx=1
for f in configs/*.wisp; do
    [ -e "$f" ] || { say "  (none found)"; exit 1; }
    i=$((i + 1))
    eval "CFG_$i=\$f"
    name=${f#configs/}; name=${name%.wisp}
    printf '  %d) %s\n' "$i" "$name"
    [ "$f" = "configs/dwlarp.wisp" ] && defidx=$i
done
n=$i
sel=$(ask "Choose config [1-$n]" "$defidx")
eval "WISP=\${CFG_$sel:-}"
[ -n "${WISP:-}" ] || { say "Invalid selection: $sel"; exit 1; }
say "→ $WISP"
say ""

# ---- 2) font backend -----------------------------------------------------
say "Font backend (pick one — it is compiled in):"
say "  1) baked     FreeType bakes a TTF at build time. No runtime deps, leanest. [default]"
say "  2) bitmap    Pixel-exact PSF/BDF baked at build time. No anti-aliasing; limited icons."
say "  3) freetype  dlopen libfreetype.so.6 at runtime; any TTF/OTF, swap via \$WISP_FONT."
b=$(ask "Choose backend [1-3]" "1")
case "$b" in
    1 | baked)    BACKEND=baked ;;
    2 | bitmap)   BACKEND=bitmap ;;
    3 | freetype) BACKEND=freetype ;;
    *) say "Invalid backend: $b"; exit 1 ;;
esac
say "→ $BACKEND"
say ""

# ---- 3) font file --------------------------------------------------------
DEF_TTF="$HOME/.local/share/fonts/MapleMono-NF-Bold.ttf"
FALLBACK=
# First emoji/CBDT font found wins as the suggested fallback default.
for c in /usr/share/fonts/noto-emoji/NotoColorEmoji.ttf \
         /usr/share/fonts/truetype/noto/NotoColorEmoji.ttf \
         "$HOME/.local/share/fonts/NotoColorEmoji.ttf"; do
    [ -f "$c" ] && { DEF_FALLBACK=$c; break; }
done
case "$BACKEND" in
    bitmap)
        say "Bitmap font: a .psf/.psfu/.bdf file (a .gz is decompressed for you)."
        say "(console fonts live under /usr/share/kbd/consolefonts/)"
        FONT=$(ask "Font path" "")
        [ -n "$FONT" ] || { say "A font path is required for the bitmap backend."; exit 1; }
        case "$FONT" in
            *.gz)
                [ -f "$FONT" ] || { say "No such file: $FONT"; exit 1; }
                mkdir -p .font-cache
                out=".font-cache/$(basename "$FONT" .gz)"
                gunzip -c "$FONT" > "$out"
                FONT="$(pwd)/$out"
                say "→ decompressed to $FONT" ;;
            *) [ -f "$FONT" ] || say "Warning: $FONT not found — the build will fail." ;;
        esac ;;
    baked)
        FONT=$(ask "TTF/OTF path" "$DEF_TTF")
        [ -f "$FONT" ] || say "Warning: $FONT not found — the build will fail." ;;
    freetype)
        FONT=$(ask "Default TTF/OTF path (\$WISP_FONT overrides at runtime)" "$DEF_TTF")
        [ -f "$FONT" ] || say "Note: $FONT not present now; freetype resolves it at runtime."
        say ""
        say "Optional fallback font for glyphs the primary lacks (emoji, CJK …)."
        say "A CBDT/sbix color font (e.g. NotoColorEmoji) renders in color; an"
        say "outline font renders monochrome. SVG-only color fonts won't render."
        say "Leave blank for none. \$WISP_FONT_FALLBACK overrides at runtime."
        FONT_FALLBACK=$(ask "Fallback font path (blank = none)" "${DEF_FALLBACK:-}")
        [ -z "$FONT_FALLBACK" ] || [ -f "$FONT_FALLBACK" ] || \
            say "Note: $FONT_FALLBACK not present now; freetype resolves it at runtime." ;;
esac
say ""

# ---- 4) persist ----------------------------------------------------------
cat > config.mk <<EOF
# Generated by ./configure — wisp build selection. Re-run ./configure or edit.
WISP = $WISP
FONT_BACKEND = $BACKEND
FONT = $FONT
EOF
[ -n "${FONT_FALLBACK:-}" ] && printf 'FONT_FALLBACK = %s\n' "$FONT_FALLBACK" >> config.mk
say "Wrote config.mk:"
sed 's/^/  /' config.mk
say ""

# ---- 5) build ------------------------------------------------------------
case "$(ask "Build and install now? [y/N]" "N")" in
    y | Y | yes | YES)
        make && make install
        say ""
        say "Installed to \$PREFIX/bin. If wisp is already running: wispctl reload" ;;
    *)
        say "config.mk is in effect — run 'make && make install' when ready." ;;
esac
